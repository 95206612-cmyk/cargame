# Street Racer Multiplayer Server
HOST=0.0.0.0
PORT=8080

# Public URL shown by /health and deployment docs.
# Use ws:// for LAN/testing, wss:// behind HTTPS reverse proxy in production.
PUBLIC_URL=ws://127.0.0.1:8080

ROOM_IDLE_MS=300000
MAX_ROOMS=100
MAX_PLAYERS_PER_ROOM=6
HEARTBEAT_MS=30000
MAX_MESSAGE_BYTES=65536
MAX_MESSAGES_PER_SECOND=90
MAX_SNAPSHOTS_PER_SECOND=36
